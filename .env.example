# Firebase Client Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin Config
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Vapi - Voice AI
NEXT_PUBLIC_VAPI_WEB_TOKEN=

# Groq - primary AI provider (14,400 req/day free, fastest inference)
GROQ_API_KEY=

# OpenRouter - secondary AI fallback (free models, ~50 req/day)
OPENROUTER_API_KEY=

# Google AI (Gemini) - final AI fallback (free tier, 1500 req/day)
GOOGLE_AI_KEY=

# Resend - email provider (100 emails/day free)
RESEND_API_KEY=

# Stripe - subscription payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=

# App URL - used for email verification links and Stripe redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000
